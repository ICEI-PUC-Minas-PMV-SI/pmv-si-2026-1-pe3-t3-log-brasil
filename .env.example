# ---------------------------------------------------------------------------
# LogBrasil – variáveis de ambiente (copie para .env na RAIZ do projeto).
# PHP carrega apenas variáveis com prefixo escolhido no config.
# ---------------------------------------------------------------------------

APP_ENV=production
# Com APP_DEBUG=1 na tela de login aparecem dicas extras para o administrador (ex.: driver PHP ausente).
APP_DEBUG=0

# URL pública até /public (usada em redirects e URLs absolutos de asset).
BASE_URL=http://localhost/LogBrasil/public

# Sessão
SESSION_NAME=logbrasil_session


# ========= Postgres (Supabase) — PHP PDO =========
# Passo a passo: docs/CONFIGURACAO_SUPABASE.md
#
# ⚠ Troque placeholders: copie HOST/USER/porta do próprio projeto em
#   Supabase → Project Settings (engrenagem) → Database → Connection parameters.
# Exemplo REAL de host: db.abcdefghij.supabase.co (não literal "SEU_PROJECT_REF").

DB_CONNECTION=pgsql
DB_HOST=db.COLE_AQUI_SUAS_LETRAS_REF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=SUA_SENHA_DO_DATABASE


# Opcional: Session pool / Transaction mode — use o hostname e porta que o painel indicar:
# DB_HOST=aws-0-REGIAO.pooler.supabase.com
# DB_PORT=6543
# DB_USERNAME=postgres.COLE_REFERENCE_ID


# Opcional REST (Next.js/outros clientes)
SUPABASE_URL=https://COLE_REFERENCE_ID.supabase.co
SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=(apenas servidor – nunca no front)


# ========= Openrouteservice =========
# Dashboard: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=SUA_API_KEY_ORG

# Perfil para rota de veículo leve até carro genérico
ORS_PROFILE=driving-car

